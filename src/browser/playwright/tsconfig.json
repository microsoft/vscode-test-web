{
	"compilerOptions": {
		"target": "ES2020",
		"module": "amd",
		"lib": ["ES2020", "webworker"],
		"outDir": "../../../out/browser/playwright",
		"declaration": true,
		"strict": true,
		"noImplicitAny": false,
		"noImplicitThis": true,
		"noUnusedLocals": true,
		"alwaysStrict": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"sourceMap": false,
		"newLine": "lf",
		"types": []
	},
	"include": [
		"."
	]
}
